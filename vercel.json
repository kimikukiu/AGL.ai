{
  "version": 2,
  "buildCommand": "cd client && npm install && npx vite build",
  "outputDirectory": "client/dist",
  "installCommand": "cd client && npm install",
  "devCommand": "cd client && npm run dev",
  "functions": {
    "api/telegram.js": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    { "source": "/api/telegram", "destination": "/api/telegram.js" },
    { "source": "/(.*)", "destination": "/client/dist/$1" }
  ]
}
