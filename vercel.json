{
  "version": 2,
  "buildCommand": "cd client && npx vite build",
  "outputDirectory": "client/dist",
  "builds": [
    { "src": "api/telegram.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/telegram", "dest": "/api/telegram.js" },
    { "src": "/(.*)", "dest": "/client/dist/$1" }
  ]
}